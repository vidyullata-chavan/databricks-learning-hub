   "source": [
    "SELECT DEPTNO, SAL AS SECOND_HIGHEST_SALARY\n",
    "FROM (\n",
    "  SELECT DEPTNO, SAL,\n",
    "         DENSE_RANK() OVER (PARTITION BY DEPTNO ORDER BY SAL DESC) AS SAL_RANK\n",
    "  FROM workspace.default.emp\n",
    ") ranked\n",
    "WHERE SAL_RANK = 2"
   ]
  }
