{
  "datasets": [
    {
      "name": "dataset1",
      "displayName": "customer",
      "queryLines": [
        "SELECT * FROM samples.tpcds_sf1.customer"
      ]
    },
    {
      "name": "307ca4d8",
      "displayName": "Customer count by Nation / Country",
      "queryLines": [
        "SELECT \r\n",
        "     INITCAP(n_name) AS Country, \r\n",
        "     COUNT(*) AS CustomerCount\r\n",
        "   FROM samples.tpch.customer\r\n",
        "   JOIN samples.tpch.nation ON n_nationkey = c_nationkey\r\n",
        "   GROUP BY Country"
      ]
    },
    {
      "name": "b3012088",
      "displayName": "Customer count by Market Segment",
      "queryLines": [
        "SELECT \r\n",
        "     c_mktsegment AS MarketSegment, \r\n",
        "     COUNT(*) AS CustomerCount\r\n",
        "   FROM samples.tpch.customer\r\n",
        "   GROUP BY MarketSegment"
      ]
    },
    {
      "name": "36d30f7f",
      "displayName": "Top account balances",
      "queryLines": [
        "SELECT \r\n",
        "     c_name AS CustomerName, \r\n",
        "     c_acctbal AS AccountBalance\r\n",
        "   FROM samples.tpch.customer\r\n",
        "   ORDER BY AccountBalance DESC\r\n",
        "   LIMIT 10"
      ]
    },
    {
      "name": "4dd7e033",
      "displayName": "Distribution of account balance",
      "queryLines": [
        "SELECT \r\n",
        "     c_custkey AS CustomerKey,\r\n",
        "     c_acctbal AS AccountBalance\r\n",
        "   FROM samples.tpch.customer"
      ]
    },
    {
      "name": "b8ca3ab7",
      "displayName": "Phone area code wise customer count (extract prefix)",
      "queryLines": [
        "SELECT \r\n",
        "     SUBSTRING(c_phone, 1, 3) AS AreaCode, \r\n",
        "     COUNT(*) AS CustomerCount\r\n",
        "   FROM samples.tpch.customer\r\n",
        "   GROUP BY AreaCode"
      ]
    }
  ],
