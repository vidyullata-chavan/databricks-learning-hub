{
  "datasets": [
    {
      "name": "72e69edd",
      "displayName": "Top Five Employees by Salary and Job Role",
      "queryLines": [
        "SELECT EMPNO, SAL, JOB FROM emp ORDER BY SAL DESC LIMIT 5;"
      ]
    },
    {
      "name": "5caab696",
      "displayName": "Employee Annual Salary Overview",
      "queryLines": [
        "SELECT EMPNO, ENAME, SAL * 12 AS ANNSAL FROM emp;"
      ]
    },
    {
      "name": "6243ebd8",
      "displayName": "Department Salary Statistics",
      "queryLines": [
        "SELECT DEPTNO, \r\n",
        "       MAX(SAL) AS MAX_SAL, \r\n",
        "       MIN(SAL) AS MIN_SAL, \r\n",
        "       AVG(SAL) AS AVG_SAL\r\n",
        "FROM emp\r\n",
        "GROUP BY DEPTNO;"
      ]
    },
    {
      "name": "ce016e13",
      "displayName": "Unique Job Titles from Employee Records",
      "queryLines": [
        "SELECT DISTINCT JOB FROM emp;"
      ]
    },
    {
      "name": "4ba32ac0",
      "displayName": "Top Four Employee Salaries Overview",
      "queryLines": [
        "SELECT * FROM emp ORDER BY SAL DESC LIMIT 4;"
      ]
    }
  ],
